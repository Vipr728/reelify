{
  "name": "reelify-desktop",
  "version": "1.0.0",
  "description": "Reelify — desktop app (Electron). Turns raw Box footage into a finished reel cut in a matched creator's style.",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "vite": "vite",
    "dev": "concurrently -k -n vite,electron -c green,cyan \"vite\" \"npm:electron:dev\"",
    "electron:dev": "wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.7.1",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  }
}
