# Reelify secrets. Copy to .env and fill in. NEVER commit real values.
# NEVER put any of these in the RN app bundle.

# --- Box (Custom Skill app, Client Credentials Grant) ---
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_ENTERPRISE_ID=
BOX_RAW_FOLDER_ID=          # folder the Skill watches; app uploads here
BOX_OUTPUT_FOLDER_ID=       # where rendered reels are stored

# --- OpenAI (Whisper + embeddings + GPT-4o) ---
OPENAI_API_KEY=

# --- Apify (TikTok/Instagram scraper actor) ---
APIFY_TOKEN=
APIFY_ACTOR_ID=             # e.g. clockworks~tiktok-scraper

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=  # edge functions + worker only (server side)
SUPABASE_ANON_KEY=          # RN app reads (with demo RLS)

# Deploy edge-function secrets with:
#   supabase secrets set --env-file .env
