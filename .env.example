# Reelify secrets. Copy to .env and fill in. NEVER commit real values.
# NEVER put server-side secrets in the React Native app bundle.

# --- Box (Custom Skill app, Client Credentials Grant) ---
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_ENTERPRISE_ID=
BOX_RAW_FOLDER_ID=
BOX_OUTPUT_FOLDER_ID=

# --- OpenAI (Whisper + embeddings + GPT-4o) ---
OPENAI_API_KEY=

# --- Apify (TikTok/Instagram scraper actor) ---
APIFY_TOKEN=
# e.g. clockworks~tiktok-scraper
APIFY_ACTOR_ID=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Deploy edge-function secrets with:
# supabase secrets set --env-file .env --project-ref <supabase-project-ref>
