# services/apify — Vihaan's pipeline secrets
# Copy to .env and fill in. Never commit real values.

OPENAI_API_KEY=
TAVILY_API_KEY=
APIFY_TOKEN=

# Apify actor for the IG scrape. Default returns flat post items with
# ownerUsername / url / videoUrl, which is the shape src/scrape.ts parses.
APIFY_IG_ACTOR=apify/instagram-scraper

# How many posts to pull per creator on the initial scrape.
APIFY_POSTS_PER_PROFILE=10

# Top-N creators Tavily should return for the niche.
TAVILY_TOP_N=5
