# Reelify secrets. Copy to .env and fill in. NEVER commit real values.
# NEVER put server-side secrets in the React Native app bundle.

# --- Box (Custom Skill app, Client Credentials Grant) ---
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_ENTERPRISE_ID=
BOX_SUBJECT_TYPE=enterprise
BOX_SUBJECT_ID=
# Optional hackathon fallback while Box CCG is not authorized.
BOX_DEVELOPER_TOKEN=
BOX_RAW_FOLDER_ID=
BOX_OUTPUT_FOLDER_ID=
# Optional: point directly at /Reelify-Hackathon/reels. If omitted, the
# server creates/uses a "reels" folder under BOX_REELS_ROOT_FOLDER_ID,
# then BOX_RAW_FOLDER_ID, then BOX_OUTPUT_FOLDER_ID.
BOX_REELS_FOLDER_ID=
BOX_REELS_ROOT_FOLDER_ID=

# --- Local upload/tagging server ---
REELIFY_SERVER_PORT=8787
# For Expo Go on a physical phone, replace localhost with your Mac LAN IP.
EXPO_PUBLIC_REELIFY_API_URL=http://localhost:8787

# --- OpenAI (Whisper + b-roll tagging + LLM edit plans) ---
OPENAI_API_KEY=
OPENAI_BROLL_MODEL=gpt-4.1-mini
# Optional override for llm-harness edit-plan generation.
OPENAI_MODEL=gpt-4o-2024-08-06

# --- Apify + creator discovery pipeline ---
APIFY_TOKEN=
APIFY_IG_ACTOR=apify/instagram-scraper
APIFY_POSTS_PER_PROFILE=10
APIFY_QUANTIFY_CONCURRENCY=3
TAVILY_API_KEY=
TAVILY_TOP_N=5

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Deploy edge-function secrets with:
# supabase secrets set --env-file .env --project-ref <supabase-project-ref>
