# Reelify Apify pipeline secrets. Copy to .env and fill in. Never commit real values.

OPENAI_API_KEY=
TAVILY_API_KEY=
APIFY_TOKEN=

# Apify actor for the IG scrape. Default is the browser-based reel scraper,
# which IG blocks far less than the cheerio-based apify/instagram-scraper.
# Input must accept a `username` string-array (or override APIFY_IG_ACTOR
# with a compatible actor).
APIFY_IG_ACTOR=apify/instagram-reel-scraper

# Reels pulled per creator. Default 1 keeps Apify hits + wall-clock minimal.
APIFY_POSTS_PER_PROFILE=1

# Creator target. creators.ts also clamps this to 3 internally.
TAVILY_TOP_N=3
